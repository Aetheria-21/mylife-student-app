<body class="indie-page min-h-screen overflow-x-hidden {{ (auth()->user()->gender ?? 'male') === 'female' ? 'theme-female' : 'theme-male' }}" data-user-gender="{{ auth()->user()->gender ?? 'male' }}">

<div class="home-app-shell">

